# =============================================
# AI ACADEMIC MENTOR — ENVIRONMENT VARIABLES
# CSE4104-7C-T05 | NUBTK 2026
# DO NOT COMMIT THE REAL .env FILE TO GITHUB
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai_academic_mentor?retryWrites=true&w=majority

# JWT Secret — MUST be changed before production (min 64 random chars)
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS_MIN
JWT_EXPIRES_IN=7d

# Admin registration code — required to register as 'admin' role.
# Keep this secret. Share it only with your supervisor/team lead, never in frontend code.
ADMIN_ACCESS_CODE=REPLACE_WITH_YOUR_OWN_SECRET_CODE

# Gemini API Key (server-side proxy — never expose in frontend)
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (for CORS — change in production to your actual domain)
CLIENT_URL=http://localhost:3000
